POSTGRES_DB=task_tracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# For docker-compose network use host "postgres"
DATABASE_URL=postgres://postgres:change-me-strong-password@postgres:5432/task_tracker?sslmode=disable
JWT_SECRET=change-me-long-random-secret
TOKEN_TTL_HOURS=24

AUTH_SERVICE_URL=http://auth-service:8081
TASK_SERVICE_URL=http://task-service:8082

# Для локального использования оставить :80. Для прода ввести домен (пример: tasks.example.com).
PUBLIC_DOMAIN=:80

BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=7
BACKUP_FILE_PREFIX=task_tracker
BACKUP_RUN_ON_START=false
